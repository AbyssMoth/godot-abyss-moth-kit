{
	"schema": 1,
	"default_branch": "main",
	"packages": [
		{
			"name": "reactive",
			"display_name": "Godot Reactive",
			"owner": "AbyssMoth",
			"repo": "godot-reactive",
			"branch": "main",
			"install_name": "reactive",
			"plugin_dir": "abyss_moth/reactive",
			"repository_url": "https://github.com/AbyssMoth/godot-reactive",
			"library_style": true,
			"public": true,
			"description": "Реактивные свойства и observables (библиотека, class_name globals)."
		},
		{
			"name": "save",
			"display_name": "Godot Save",
			"owner": "AbyssMoth",
			"repo": "godot-save",
			"branch": "main",
			"install_name": "save",
			"plugin_dir": "abyss_moth/save",
			"repository_url": "https://github.com/AbyssMoth/godot-save",
			"library_style": true,
			"public": true,
			"description": "Сохранение состояния в JSON (библиотека, class_name globals)."
		},
		{
			"name": "export_sanitizer",
			"display_name": "Export Sanitizer",
			"owner": "AbyssMoth",
			"repo": "godot-export-sanitizer",
			"branch": "main",
			"install_name": "export_sanitizer",
			"plugin_dir": "abyss_moth/export_sanitizer",
			"repository_url": "https://github.com/AbyssMoth/godot-export-sanitizer",
			"library_style": false,
			"public": true,
			"description": "Убирает dev-инструменты и их следы из экспортных сборок по конфигу с профилями (common/web/android)."
		},
		{
			"name": "atlas_forge",
			"display_name": "Atlas Forge",
			"owner": "AbyssMoth",
			"repo": "godot-atlas-forge",
			"branch": "main",
			"install_name": "atlas_forge",
			"plugin_dir": "abyss_moth/atlas_forge",
			"repository_url": "https://github.com/AbyssMoth/godot-atlas-forge",
			"library_style": false,
			"public": true,
			"description": "Слайсер атласов: сетка + авто по альфа-кляксам, рефреш с сохранением UID."
		},
		{
			"name": "godot_ai",
			"display_name": "Godot AI (MCP)",
			"owner": "hi-godot",
			"repo": "godot-ai",
			"branch": "main",
			"install_name": "godot_ai",
			"plugin_dir": "godot_ai",
			"source_subdir": "plugin/addons/godot_ai",
			"repository_url": "https://github.com/hi-godot/godot-ai",
			"library_style": false,
			"declares_autoloads": true,
			"public": true,
			"description": "MCP-мост редактор <-> AI (dev-инструмент). Ставится только editor-аддон в addons/godot_ai; сам MCP-сервер запускается через uvx отдельно."
		}
	],
	"presets": {
		"base": ["reactive", "save", "export_sanitizer"],
		"mobile_2d": ["reactive", "save"],
		"dev_tools": ["godot_ai", "atlas_forge"]
	}
}
