			"library_style": false,
			"public": true,
			"description": "Убирает dev-инструменты и их следы из экспортных сборок по конфигу с профилями (common/web/android)."
		},
		{
			"name": "atlas_forge",
			"display_name": "Atlas Forge",
			"kind": "studio",
			"owner": "AbyssMoth",
			"repo": "godot-atlas-forge",
			"branch": "main",
			"install_name": "atlas_forge",
			"plugin_dir": "abyss_moth/atlas_forge",
			"repository_url": "https://github.com/AbyssMoth/godot-atlas-forge",
			"library_style": false,
			"public": true,
			"description": "Слайсер атласов: сетка + авто по альфа-кляксам, рефреш с сохранением UID."
		},
		{
			"name": "node_process_toggle",
			"display_name": "Node Process Toggle",
			"kind": "studio",
			"owner": "AbyssMoth",
			"repo": "godot-node-process-toggle",
			"branch": "main",
			"install_name": "node_process_toggle",
			"plugin_dir": "abyss_moth/node_process_toggle",
			"repository_url": "https://github.com/AbyssMoth/godot-node-process-toggle",
			"library_style": false,
			"public": true,
			"description": "Чекбокс включения/выключения ноды в Inspector (аналог enabled/SetActive из Unity)."
		},
		{
			"name": "promo_shot",
			"display_name": "Promo Shot",
			"kind": "studio",
			"owner": "AbyssMoth",
			"repo": "godot-promo-shot",
			"branch": "main",
			"install_name": "promo_shot",
			"plugin_dir": "abyss_moth/promo_shot",
			"repository_url": "https://github.com/AbyssMoth/godot-promo-shot",
			"library_style": false,
			"declares_autoloads": true,
			"public": true,
			"description": "Промо-скриншоты одной клавишей: enum-пресеты площадок (YouTube/Steam/itch.io/Google Play/соцсети), скрытие debug-нод, авто-папка с .gitignore, конвертация в JPG/WEBP и рекордер через ffmpeg. API PromoShot.capture()."
		},
		{
			"name": "godot_ai",
			"display_name": "AI (MCP)",
			"kind": "external",
			"owner": "hi-godot",
			"repo": "godot-ai",
			"branch": "main",
			"install_name": "godot_ai",
			"plugin_dir": "godot_ai",
			"source_subdir": "plugin/addons/godot_ai",
			"repository_url": "https://github.com/hi-godot/godot-ai",
			"library_style": false,
			"declares_autoloads": true,
			"public": true,
			"description": "MCP-мост редактор <-> AI (dev-инструмент). Ставится только editor-аддон в addons/godot_ai; сам MCP-сервер запускается через uvx отдельно."
		}
	],
	"presets": {
		"base": ["reactive", "save", "export_sanitizer", "node_process_toggle"],
		"mobile_2d": ["reactive", "save"],
		"dev_tools": ["godot_ai", "atlas_forge"],
		"promo": ["promo_shot"]
	}
